# Copy to `.env` and fill in values. Never commit `.env`.

# --- Database (required) ---
# Local (after `docker compose up -d`):
# DATABASE_URL="postgresql://qaptain:qaptain@localhost:5432/qaptain"
# Or use Neon / any hosted Postgres:
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# --- Auth (required for login) ---
NEXTAUTH_SECRET="your-super-secret-random-string-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# --- Redis + worker (optional but recommended for discovery / runs / expand jobs) ---
# If unset, API routes run jobs inline on the web process (slower, no queue isolation).
#
# LOCAL Docker Compose Redis:
#   REDIS_URL="redis://localhost:6379"
#
# UPSTASH hosted Redis (use the standard redis:// URL, NOT the REST URL):
#   Get this from Upstash Console → your database → "Redis Connect" → ioredis tab.
#   REDIS_URL="rediss://default:<password>@<host>.upstash.io:6379"
#
# ⚠️  The UPSTASH_REDIS_REST_* vars below are for the @upstash/redis REST SDK only.
#     BullMQ / ioredis require a standard redis:// or rediss:// URL in REDIS_URL.
UPSTASH_REDIS_REST_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
REDIS_URL="rediss://default:your-password@your-host.upstash.io:6379"

# --- Supabase (module memory — replaces ChromaDB) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="your-supabase-publishable-key"
# Server-side key (bypasses RLS — get from Supabase Dashboard → Settings → API):
# SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# --- AI (use Azure OpenAI and/or OpenAI as configured in code) ---
LLM_PROVIDER="azure"
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_ENDPOINT="https://your-resource.openai.azure.com/"
AZURE_OPENAI_DEPLOYMENT="your-deployment-name"
