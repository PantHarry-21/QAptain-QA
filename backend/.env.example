# ── QAptain Backend Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in the values.

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false

# ── Database (Neon PostgreSQL recommended) ─────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?ssl=require

# ── Redis (Upstash recommended for cloud) ──────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://default:<token>@<host>.upstash.io:6379
REDIS_URL=redis://localhost:6379

# ── Security — MUST change for production ──────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-in-production-minimum-32-chars

# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── AI Provider ─────────────────────────────────────────────────────────────────
LLM_PROVIDER=azure

# Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# OpenAI (fallback)
OPENAI_API_KEY=your_openai_key

# Gemini (optional)
GEMINI_API_KEY=your_gemini_key

# ── CORS — set to your Vercel frontend URL ─────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ── Browser Automation ─────────────────────────────────────────────────────────
SELENIUM_HEADLESS=true

# ── Email (optional) ───────────────────────────────────────────────────────────
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_app_password
